# CreatorKart Gear Apache routing and 404 handling
# Place this file in the project web root.

DirectoryIndex index.php
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve existing files/directories as-is.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Allow extensionless routes: /about -> /about.php
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L,QSA]

    # Product shortcut route: /product/some-slug -> /product.php?slug=some-slug
    RewriteRule ^product/([A-Za-z0-9-]+)/?$ product.php?slug=$1 [L,QSA]

    # Force a local 404 handler so Apache never loops on missing ErrorDocument paths.
    RewriteRule ^ 404.php [L]
</IfModule>
